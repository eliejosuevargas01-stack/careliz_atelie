{
  "name": "agenda-careliz",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c \"#d76215,#43200d\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm run build -ws --if-present",
    "db:push": "npm --workspace apps/api run db:push",
    "db:seed": "npm --workspace apps/api run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
